# Tell pnpm to install node_modules into the static/js directory so that
# OpenCV.js and other client assets are co-located with scanner.js and
# served by FastAPI's StaticFiles mount.
#
# pnpm v11: project-scoped settings are read from this file.
# Run `pnpm install` from the project root to populate static/js/node_modules/.
modules-dir=flight_card_scanner/static/js/node_modules
virtual-store-dir=flight_card_scanner/static/js/.pnpm
